[gd_resource type="Theme" format=3 uid="uid://bui1theme01"]

; Project-wide default theme. Godot ships a cramped default (tiny font, ~4px
; button padding); this replaces that floor with readable text and big, tappable
; buttons everywhere. Per-control overrides still win, so this only lifts the
; baseline — it never clobbers an intentional size. Wired via
; project.godot -> [gui] theme/custom.

[sub_resource type="StyleBoxFlat" id="btn_normal"]
content_margin_left = 24.0
content_margin_top = 14.0
content_margin_right = 24.0
content_margin_bottom = 14.0
bg_color = Color(0.2, 0.21, 0.28, 1)
border_width_left = 1
border_width_top = 1
border_width_right = 1
border_width_bottom = 1
border_color = Color(0.38, 0.4, 0.5, 1)
corner_radius_top_left = 8
corner_radius_top_right = 8
corner_radius_bottom_right = 8
corner_radius_bottom_left = 8

